    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.0.0",
    "@sentry/nextjs": "^8.0.0",
    "@socialgouv/matomo-next": "^1.11.0",
    "@tabler/icons-react": "^3.44.0",
    "next": "^15.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-gfm": "^4.0.1",
    "tss-react": "^4.9.20"
